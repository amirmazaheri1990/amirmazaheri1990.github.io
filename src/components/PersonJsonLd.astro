---
import { site } from '../data/site';

const sameAs = Object.values(site.links).filter(
  (u): u is string => typeof u === 'string' && u.length > 0,
);

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  email: `mailto:${site.email}`,
  url: site.url,
  image: new URL(site.profileImage, site.url).toString(),
  sameAs,
  knowsAbout: [
    'Computer Vision',
    'Deep Learning',
    'Machine Learning',
    'Vision and Language',
    'Visual Question Answering',
    'Video Understanding',
  ],
};
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(person)}
/>
