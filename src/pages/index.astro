---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base>
  <section class="profile">
    <img src={site.profileImage} alt={`Portrait of ${site.name}`} width="144" height="144" />
    <div>
      <h1>{site.name}</h1>
      <p class="role muted">{site.role}</p>
    </div>
  </section>

  <p class="tagline">{site.tagline}</p>

  <div class="row">
    <a href="/projects">Projects</a>
    <span class="faint">·</span>
    <a href="/cv">CV</a>
    <span class="faint">·</span>
    <a href={site.links.github} rel="me noopener">GitHub</a>
    <span class="faint">·</span>
    <a href={site.links.linkedin} rel="me noopener">LinkedIn</a>
    <span class="faint">·</span>
    <a href={`mailto:${site.email}`}>{site.email}</a>
  </div>

  <h2><span class="section-emoji" aria-hidden="true">👋</span> About</h2>
  <p>
    I'm a Computer Vision Research Scientist with deep expertise in large-scale
    video understanding, Vision-Language Models (VLMs), and multimodal AI systems.
    I currently work as a Staff ML Engineer at <strong>Warner Bros. Discovery
    (HBO)</strong>, where I lead video understanding and content moderation systems
    for the streaming platform.
  </p>
  <p>
    I hold a PhD from UCF's <a href="https://www.crcv.ucf.edu/" rel="noopener">Center
    for Research in Computer Vision (CRCV)</a>, advised by
    <a href="https://www.crcv.ucf.edu/person/mubarak-shah/" rel="noopener">Prof. Mubarak Shah</a>.
    My dissertation focused on <em>Video Content Understanding Using Text</em>.
    I have authored publications at CVPR, ICCV, ECCV, EMNLP, and AAAI, and hold
    multiple US patents.
  </p>

  <h2><span class="section-emoji" aria-hidden="true">🔭</span> Current focus</h2>
  <ul>
    <li>Large-scale video understanding and temporal reasoning.</li>
    <li>Vision-Language Models (VLMs) for content moderation and in-video search.</li>
    <li>LLM-enhanced metadata generation for fine-grained video discovery.</li>
    <li>Production-scale multimodal AI — from research to real-world deployment.</li>
  </ul>

  {featured.length > 0 && (
    <>
      <h2><span class="section-emoji" aria-hidden="true">🧪</span> Selected projects</h2>
      <div class="stack">
        {featured.map((p) => {
          const venues = p.data.publications.map((pub) => `${pub.venue} ${pub.year}`);
          const hasPatent = p.data.patents.length > 0;
          return (
            <a href={`/projects/${p.slug}`} class="card project-card">
              <div class="row-between">
                <h3>{p.data.title}</h3>
                {p.data.period && <span class="date">{p.data.period}</span>}
              </div>
              <p class="muted">{p.data.summary}</p>
              <div class="row">
                {venues.map((v) => <span class="badge venue">{v}</span>)}
                {hasPatent && <span class="badge patent">Patent</span>}
              </div>
            </a>
          );
        })}
      </div>
      <p><a href="/projects">See all projects →</a></p>
    </>
  )}
</Base>

<style>
.project-card { display: block; color: inherit; }
.project-card h3 { color: var(--text); }
.badge {
  display: inline-block;
  padding: 0.1rem 0.5rem;
  font-size: 0.8125rem;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid transparent;
}
.badge.venue {
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  border-color: color-mix(in srgb, var(--accent) 25%, transparent);
}
.badge.patent {
  background: color-mix(in srgb, #f59e0b 12%, transparent);
  color: #b45309;
  border-color: color-mix(in srgb, #f59e0b 30%, transparent);
}
@media (prefers-color-scheme: dark) {
  .badge.patent { color: #fbbf24; }
}
</style>
