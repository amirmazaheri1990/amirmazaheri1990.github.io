---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const pubs = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);

const byYear = pubs.reduce<Record<number, typeof pubs>>((acc, pub) => {
  (acc[pub.data.year] ||= []).push(pub);
  return acc;
}, {});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const linkLabel: Record<string, string> = {
  pdf: 'PDF',
  arxiv: 'arXiv',
  code: 'Code',
  project: 'Project page',
  video: 'Video',
  slides: 'Slides',
  bibtex: 'BibTeX',
  doi: 'DOI',
};

const scholarlyArticles = pubs.map((pub) => ({
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: pub.data.title,
  name: pub.data.title,
  author: pub.data.authors.map((name) => ({ '@type': 'Person', name })),
  datePublished: String(pub.data.year),
  isPartOf: pub.data.venue,
  url: pub.data.links.project || pub.data.links.pdf || pub.data.links.arxiv || site.url,
}));
---

<Base title="Publications" description="Peer-reviewed publications by Amir Mazaheri.">
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(scholarlyArticles)}
  />

  <h1>Publications</h1>
  <p class="tagline">Peer-reviewed work, most recent first.</p>

  {years.map((year) => (
    <>
      <h2>{year}</h2>
      <div class="stack">
        {byYear[year].map((pub) => (
          <article class="card">
            <div class="row-between">
              <h3>{pub.data.title}</h3>
              <span class="date">{pub.data.venue} {pub.data.year}</span>
            </div>
            <p class="muted">{pub.data.authors.join(', ')}</p>
            {pub.data.tags.length > 0 && (
              <p class="row">
                {pub.data.tags.map((t) => <span class="tag">{t}</span>)}
              </p>
            )}
            {Object.entries(pub.data.links).filter(([, v]) => v).length > 0 && (
              <p class="row">
                {Object.entries(pub.data.links)
                  .filter(([, v]) => v)
                  .map(([k, v]) => (
                    <a href={v as string} rel="noopener">{linkLabel[k] ?? k}</a>
                  ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </>
  ))}
</Base>
